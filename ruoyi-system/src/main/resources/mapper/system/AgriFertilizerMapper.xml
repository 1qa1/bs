<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriFertilizerMapper">

    <resultMap type="AgriFertilizer" id="AgriFertilizerResult">
        <result property="id"    column="id"    />
        <result property="fid"    column="fid"    />
        <result property="gid"    column="gid"    />
        <result property="pid"    column="pid"    />
        <result property="name"    column="name"    />
        <result property="company"    column="company"    />
        <result property="batchNo"    column="batch_no"    />
        <result property="useTime"    column="use_time"    />
        <result property="txHash"    column="tx_hash"    />
        <result property="timeStamp"    column="time_stamp"    />
        <result property="status"    column="status"    />
    </resultMap>

    <sql id="selectAgriFertilizerVo">
        select id, fid, gid, pid, name, company, batch_no, use_time, tx_hash, time_stamp, status from agri_fertilizer
    </sql>

    <select id="selectAgriFertilizerList" parameterType="AgriFertilizer" resultMap="AgriFertilizerResult">
        <include refid="selectAgriFertilizerVo"/>
        <where>
            <if test="fid != null  and fid != ''"> and fid = #{fid}</if>
            <if test="gid != null  and gid != ''"> and gid = #{gid}</if>
            <if test="pid != null  and pid != ''"> and pid = #{pid}</if>
            <if test="name != null  and name != ''"> and name like concat('%', #{name}, '%')</if>
        </where>
    </select>

    <select id="selectAgriFertilizerById" parameterType="Long" resultMap="AgriFertilizerResult">
        <include refid="selectAgriFertilizerVo"/>
        where id = #{id}
    </select>

    <select id="selectFertilizerByGid" parameterType="string" resultMap="AgriFertilizerResult" >
        <include refid="selectAgriFertilizerVo"/>
        where gid = #{gid}
    </select>

    <select id="selectFertilizerByFid" parameterType="string" resultMap="AgriFertilizerResult">
        <include refid="selectAgriFertilizerVo"/>
        where fid = #{fid}
    </select>

    <insert id="insertAgriFertilizer" parameterType="AgriFertilizer" useGeneratedKeys="true" keyProperty="id">
        insert into agri_fertilizer
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="fid != null">fid,</if>
            <if test="gid != null">gid,</if>
            <if test="pid != null">pid,</if>
            <if test="name != null">name,</if>
            <if test="company != null">company,</if>
            <if test="batchNo != null">batch_no,</if>
            <if test="useTime != null">use_time,</if>
            <if test="status != null">status,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="fid != null">#{fid},</if>
            <if test="gid != null">#{gid},</if>
            <if test="pid != null">#{pid},</if>
            <if test="name != null">#{name},</if>
            <if test="company != null">#{company},</if>
            <if test="batchNo != null">#{batchNo},</if>
            <if test="useTime != null">#{useTime},</if>
            <if test="status != null">#{status},</if>
        </trim>
    </insert>

    <update id="updateAgriFertilizer" parameterType="AgriFertilizer">
        update agri_fertilizer
        <trim prefix="SET" suffixOverrides=",">
            <if test="fid != null">fid = #{fid},</if>
            <if test="gid != null">gid = #{gid},</if>
            <if test="pid != null">pid = #{pid},</if>
            <if test="name != null">name = #{name},</if>
            <if test="company != null">company = #{company},</if>
            <if test="batchNo != null">batch_no = #{batchNo},</if>
            <if test="useTime != null">use_time = #{useTime},</if>
            <if test="txHash != null">tx_hash = #{txHash},</if>
            <if test="timeStamp != null">time_stamp = #{timeStamp},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAgriFertilizerById" parameterType="Long">
        delete from agri_fertilizer where id = #{id}
    </delete>

    <delete id="deleteAgriFertilizerByIds" parameterType="String">
        delete from agri_fertilizer where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteFertilizerByGid" parameterType="string">
        delete from agri_fertilizer where gid = #{gid}
    </delete>
</mapper>