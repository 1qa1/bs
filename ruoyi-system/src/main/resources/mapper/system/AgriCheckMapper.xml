<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.AgriCheckMapper">

    <resultMap type="AgriCheck" id="AgriCheckResult">
        <result property="id"    column="id"    />
        <result property="cid"    column="cid"    />
        <result property="pid"    column="pid"    />
        <result property="gid"    column="gid"    />
        <result property="projName"    column="proj_name"    />
        <result property="types"    column="types"    />
        <result property="result"    column="result"    />
        <result property="uploadsUrl"    column="uploads_url"    />
        <result property="txHash"    column="tx_hash"    />
        <result property="timeStamp"    column="time_stamp"    />
        <result property="status"    column="status"    />
    </resultMap>

    <sql id="selectAgriCheckVo">
        select id, cid, pid, gid, proj_name, types, result, uploads_url, tx_hash, time_stamp, status from agri_check
    </sql>

    <select id="selectAgriCheckList" parameterType="AgriCheck" resultMap="AgriCheckResult">
        <include refid="selectAgriCheckVo"/>
        <where>
            <if test="cid != null  and cid != ''"> and cid = #{cid}</if>
            <if test="pid != null  and pid != ''"> and pid = #{pid}</if>
            <if test="gid != null  and gid != ''"> and gid = #{gid}</if>
            <if test="projName != null  and projName != ''"> and proj_name like concat('%', #{projName}, '%')</if>
        </where>
    </select>

    <select id="selectAgriCheckById" parameterType="Long" resultMap="AgriCheckResult">
        <include refid="selectAgriCheckVo"/>
        where id = #{id}
    </select>

    <select id="selectCheckByPid" resultMap="AgriCheckResult" parameterType="string">
        <include refid="selectAgriCheckVo"/>
        where pid = #{pid}
    </select>

    <select id="selectCheckByCid" parameterType="string" resultMap="AgriCheckResult">
        <include refid="selectAgriCheckVo"/>
        where cid = #{cid}
    </select>

    <insert id="insertAgriCheck" parameterType="AgriCheck" useGeneratedKeys="true" keyProperty="id">
        insert into agri_check
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="cid != null">cid,</if>
            <if test="pid != null">pid,</if>
            <if test="gid != null">gid,</if>
            <if test="projName != null">proj_name,</if>
            <if test="types != null">types,</if>
            <if test="result != null">result,</if>
            <if test="uploadsUrl != null">uploads_url,</if>
            <if test="status != null">status,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="cid != null">#{cid},</if>
            <if test="pid != null">#{pid},</if>
            <if test="gid != null">#{gid},</if>
            <if test="projName != null">#{projName},</if>
            <if test="types != null">#{types},</if>
            <if test="result != null">#{result},</if>
            <if test="uploadsUrl != null">#{uploadsUrl},</if>
            <if test="status != null">#{status},</if>
        </trim>
    </insert>

    <update id="updateAgriCheck" parameterType="AgriCheck">
        update agri_check
        <trim prefix="SET" suffixOverrides=",">
            <if test="cid != null">cid = #{cid},</if>
            <if test="pid != null">pid = #{pid},</if>
            <if test="gid != null">gid = #{gid},</if>
            <if test="projName != null">proj_name = #{projName},</if>
            <if test="types != null">types = #{types},</if>
            <if test="result != null">result = #{result},</if>
            <if test="uploadsUrl != null">uploads_url = #{uploadsUrl},</if>
            <if test="txHash != null">tx_hash = #{txHash},</if>
            <if test="timeStamp != null">time_stamp = #{timeStamp},</if>
            <if test="status != null">status = #{status},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteAgriCheckById" parameterType="Long">
        delete from agri_check where id = #{id}
    </delete>

    <delete id="deleteAgriCheckByIds" parameterType="String">
        delete from agri_check where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteCheckByPid" parameterType="string">
        delete from agri_check where pid = #{pid}
    </delete>
</mapper>